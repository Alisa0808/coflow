# Copy this file to either:
# - /Users/qiutian/Projects/apps/coding-agent-canva/.env.local
# - /Users/qiutian/Projects/apps/coding-agent-canva/coflow/.env.local
#
# Then restart with:
# npm run serve
#
# Do not commit the real key.
ATLASCLOUD_API_KEY=

# Optional overrides:
# ATLASCLOUD_API_BASE_URL=https://api.atlascloud.ai/api/v1
# ATLASCLOUD_IMAGE_EDIT_MODEL=openai/gpt-image-2/edit
# ATLASCLOUD_IMAGE_TEXT_MODEL=openai/gpt-image-2/text-to-image
# ATLASCLOUD_VIDEO_IMAGE_MODEL=bytedance/seedance-2.0/reference-to-video
# ATLASCLOUD_VIDEO_TEXT_MODEL=bytedance/seedance-2.0/text-to-video
# ATLASCLOUD_IMAGE_SIZE=1024x1024
# ATLASCLOUD_VIDEO_DURATION=5
# ATLASCLOUD_VIDEO_RESOLUTION=720p
# ATLASCLOUD_VIDEO_RATIO=adaptive
# ATLASCLOUD_VIDEO_BITRATE_MODE=standard
# ATLASCLOUD_VIDEO_AUDIO=true
# ATLASCLOUD_VIDEO_WATERMARK=false
# ATLASCLOUD_VIDEO_RETURN_LAST_FRAME=false
# ATLAS_POLL_INTERVAL_MS=2000

# Optional custom provider endpoints for advanced users.
# These keep the open-source project provider-neutral; Atlas Cloud remains the best-supported default.
# SEEDANCE_PROVIDER_ENDPOINT=
# SEEDANCE_PROVIDER_API_KEY=
# KLING_PROVIDER_ENDPOINT=
# KLING_PROVIDER_API_KEY=
# REAL_PROVIDER_ENDPOINT=
# REAL_PROVIDER_API_KEY=
